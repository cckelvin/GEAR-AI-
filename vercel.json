{
  "version": 2,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.ts" },
    { "source": "/((?!chat|editor|dashboard|integrations|auth|domains|view|static|assets|favicon|manifest|logo|robots.txt|.*\\..*).*)", "destination": "/api/index.ts" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
